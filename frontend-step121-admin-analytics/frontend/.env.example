VITE_API_URL=https://api.example.com/api
VITE_DEBUG_API=false

# Optional frontend fallback for calls.
# In normal production use, Friendscape fetches runtime ICE/TURN config
# from GET /api/calls/config and you can leave the values below empty.
VITE_WEBRTC_ICE_SERVERS_JSON=
VITE_WEBRTC_ICE_TRANSPORT_POLICY=all
VITE_WEBRTC_BUNDLE_POLICY=max-bundle
VITE_WEBRTC_RTCP_MUX_POLICY=require
VITE_WEBRTC_ICE_CANDIDATE_POOL_SIZE=6
