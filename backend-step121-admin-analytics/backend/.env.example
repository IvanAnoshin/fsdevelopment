APP_ENV=production
APP_VERSION=1.0.0
PORT=8080
APP_PUBLIC_URL=https://friendscape.ru
ALLOWED_ORIGINS=https://friendscape.ru,https://www.friendscape.ru
TRUSTED_PROXIES=127.0.0.1,::1
ENABLE_DEV_ADMIN_ROUTE=false
ADMIN_BOOTSTRAP_TOKEN=CHANGE_ME
ERROR_WEBHOOK_URL=

JWT_SECRET=CHANGE_ME

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_NAME=friendscape
DB_SSLMODE=disable
DB_TIMEZONE=Europe/Moscow
DB_MAX_OPEN_CONNS=40
DB_MAX_IDLE_CONNS=20
DB_CONN_MAX_LIFETIME_MIN=30
DB_CONN_MAX_IDLE_MIN=10

MEDIA_DRIVER=local
MEDIA_BASE_URL=/media
MEDIA_ROOT=./media
MEDIA_MAGICK_BIN=magick

WEBRTC_STUN_URLS=stun:turn.friendscape.ru:3478
WEBRTC_TURN_URLS=turn:turn.friendscape.ru:3478?transport=udp,turn:turn.friendscape.ru:3478?transport=tcp,turns:turn.friendscape.ru:5349?transport=tcp
WEBRTC_TURN_SECRET=CHANGE_ME
WEBRTC_TURN_TTL_SECONDS=3600
WEBRTC_ICE_TRANSPORT_POLICY=all
WEBRTC_BUNDLE_POLICY=max-bundle
WEBRTC_RTCP_MUX_POLICY=require
WEBRTC_ICE_CANDIDATE_POOL_SIZE=6

VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME
VAPID_SUBJECT=mailto:admin@friendscape.ru

DFSN_EXPORT_MAX_ROWS=250000