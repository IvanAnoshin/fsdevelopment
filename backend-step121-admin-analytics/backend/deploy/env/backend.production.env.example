APP_ENV=production
APP_VERSION=1.0.0
PORT=8080
APP_PUBLIC_URL=https://app.example.com
ALLOWED_ORIGINS=https://app.example.com
TRUSTED_PROXIES=127.0.0.1,::1
ENABLE_DEV_ADMIN_ROUTE=false
ADMIN_BOOTSTRAP_TOKEN=replace-with-a-random-32-plus-char-secret-when-enabled
ERROR_WEBHOOK_URL=

JWT_SECRET=replace-with-a-random-32-plus-char-secret

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=friendscape
DB_PASSWORD=replace-me
DB_NAME=friendscape
DB_SSLMODE=require
DB_TIMEZONE=Europe/Vilnius
DB_MAX_OPEN_CONNS=40
DB_MAX_IDLE_CONNS=20
DB_CONN_MAX_LIFETIME_MIN=30
DB_CONN_MAX_IDLE_MIN=10

MEDIA_DRIVER=local
MEDIA_BASE_URL=/media
MEDIA_ROOT=/opt/friendscape/backend/media
MEDIA_MAGICK_BIN=magick
MESSAGE_MEDIA_CLEANUP_ENABLED=true
MESSAGE_MEDIA_CLEANUP_INTERVAL=1h
MESSAGE_MEDIA_ORPHAN_AGE=24h

WEBRTC_STUN_URLS=stun:turn.example.com:3478
WEBRTC_TURN_URLS=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp,turns:turn.example.com:5349?transport=tcp
WEBRTC_TURN_SECRET=replace-with-turn-shared-secret
WEBRTC_TURN_TTL_SECONDS=3600
WEBRTC_ICE_TRANSPORT_POLICY=all
WEBRTC_BUNDLE_POLICY=max-bundle
WEBRTC_RTCP_MUX_POLICY=require
WEBRTC_ICE_CANDIDATE_POOL_SIZE=6

VAPID_PUBLIC_KEY=replace-me
VAPID_PRIVATE_KEY=replace-me

DFSN_EXPORT_MAX_ROWS=250000
